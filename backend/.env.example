# Trading Analysis API - Environment Configuration
# Copy this file to .env and modify as needed

# Application Settings
APP_NAME="Trading Analysis API"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Automated technical analysis engine for stocks and crypto"
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# Feature Flags
APP_ENABLE_WEBSOCKET=true
APP_ENABLE_METRICS=true
APP_ENABLE_CACHE=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s | %(levelname)s | %(name)s | %(message)s"
LOG_JSON_FORMAT=false
LOG_FILE_PATH=/var/log/trading-api/app.log

# Security
SECURITY_CORS_ORIGINS="*"
SECURITY_RATE_LIMIT_REQUESTS=100
SECURITY_RATE_LIMIT_WINDOW=60

# Yahoo Finance
YF_TIMEOUT_SECONDS=30
YF_MAX_RETRIES=3
YF_RETRY_DELAY=1.0
