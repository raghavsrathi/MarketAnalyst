# ============================================
# UPSTOX API CONFIGURATION
# ============================================
UPSTOX_API_KEY=your_upstox_api_key_here
UPSTOX_SECRET=your_upstox_secret_here
UPSTOX_REDIRECT_URI=http://localhost:8080/callback

# Token will be auto-populated after OAuth flow
UPSTOX_ACCESS_TOKEN=

# ============================================
# DATABASE CONFIGURATION - MS SQL SERVER
# ============================================

# Individual components (alternative to connection string)
DB_HOST=localhost
DB_PORT=1433
DB_NAME=indian_stocks
DB_USER=admin
DB_PASSWORD=your_password_here
DB_ENCRYPT=true
DB_TRUST_CERT=true


# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# CORS CONFIGURATION
# ============================================
# Local development
FRONTEND_URL=http://localhost:5173

# Production (Netlify) - Uncomment when deploying
# FRONTEND_URL=https://trading-chart-analyzer.netlify.app

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# PERFORMANCE SETTINGS
# ============================================
# Slow request threshold (ms) - logs requests taking longer
SLOW_REQUEST_THRESHOLD=1000

# Cache TTLs (seconds)
ANALYSIS_CACHE_TTL=120
PRICE_CACHE_TTL=10
ORDER_DEDUPLICATION_TTL=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# Timeouts (ms)
YFINANCE_TIMEOUT=15000
UPSTOX_TIMEOUT=10000

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=1000

# ============================================
# CACHE (optional - Redis)
# ============================================
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300
